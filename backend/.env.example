NODE_ENV=production
PORT=10000

# PostgreSQL. Remote databases verify the server certificate by default.
DATABASE_URL=postgresql://app_user:replace_me@db.example.com:5432/stada_content
DATABASE_SSL_MODE=verify-full
# Set this only when your database provider uses a private CA. Use a multiline
# value in the hosting dashboard; do not commit the real certificate here.
# DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
DATABASE_POOL_MAX=5

# Global and country-scoped administrator accounts.
ADMIN_LOGIN=replace_with_admin_login
ADMIN_PASSWORD=replace_with_a_long_random_password
ADMIN_SESSION_TTL_MS=28800000
ADMIN_LOGIN_MAX_ATTEMPTS=8
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_COOKIE_SAME_SITE=Strict
ADMIN_CORS_ORIGINS=https://admin.stada.kz
CORS_ORIGINS=https://stada.kz

# Cloudinary credentials are backend-only secrets.
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
CLOUDINARY_UPLOAD_FOLDER=stada/hero
CLOUDINARY_PRODUCT_UPLOAD_FOLDER=stada/products

# Request and HTTP-server limits.
MAX_LOGIN_BODY_BYTES=16384
MAX_JSON_BODY_BYTES=1048576
MAX_IMAGE_UPLOAD_BODY_BYTES=12582912
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=15000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SERVER_MAX_REQUESTS_PER_SOCKET=100
